{
  "name": "cabaret",
  "version": "0.0.0",
  "private": true,
  "description": "Personal/local-first code review tool inspired by Jane Street's Iron",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b && tsc -p tsconfig.test.json",
    "test": "vitest run",
    "lint": "eslint .",
    "clean": "tsc -b --clean && rm -rf packages/*/dist"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}
