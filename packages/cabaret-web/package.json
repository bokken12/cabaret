{
  "name": "cabaret-web",
  "description": "Cabaret's review pages as a standalone browser app over the GitHub API",
  "private": true,
  "type": "module",
  "dependencies": {
    "@shikijs/core": "^4.3.1",
    "@shikijs/engine-javascript": "^4.3.1",
    "@shikijs/langs": "^4.3.1",
    "@shikijs/themes": "^4.3.1",
    "cabaret-core": "workspace:*",
    "cabaret-github": "workspace:*",
    "cabaret-views": "workspace:*"
  },
  "devDependencies": {
