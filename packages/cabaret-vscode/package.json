{
  "name": "cabaret-vscode",
  "displayName": "Cabaret",
  "description": "Cabaret's review pages as read-only text buffers in VS Code",
  "private": true,
  "version": "0.0.0",
  "publisher": "cabaret",
  "type": "module",
  "main": "./dist/extension.cjs",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onFileSystem:cabaret"
  ],
  "contributes": {
    "commands": [
      {
        "command": "cabaret.todo",
        "title": "Cabaret: Todo"
      },
      {
        "command": "cabaret.show",
        "title": "Cabaret: Show Change"
      },
      {
        "command": "cabaret.openTarget",
        "title": "Cabaret: Open Target at Cursor"
      },
      {
        "command": "cabaret.refresh",
        "title": "Cabaret: Refresh"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "cabaret.openTarget",
          "when": "resourceScheme == cabaret"
        },
        {
          "command": "cabaret.refresh",
          "when": "resourceScheme == cabaret"
        }
      ]
    },
    "keybindings": [
      {
        "command": "cabaret.openTarget",
        "key": "enter",
        "when": "editorTextFocus && resourceScheme == cabaret"
      },
      {
        "command": "cabaret.refresh",
        "key": "r",
        "when": "editorTextFocus && resourceScheme == cabaret"
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "heading",
        "description": "A section heading in a Cabaret page"
      }
    ],
    "semanticTokenScopes": [
      {
        "scopes": {
          "heading": [
            "markup.heading"
          ]
        }
      }
    ]
  },
  "dependencies": {
    "cabaret-core": "workspace:*",
    "cabaret-node": "workspace:*",
    "cabaret-views": "workspace:*"
  },
  "scripts": {
    "build": "tsc -b && esbuild src/extension.ts --bundle --conditions=source --external:vscode --platform=node --format=cjs --outfile=dist/extension.cjs"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "esbuild": "^0.28.1",
    "fast-check": "^4.8.0"
  }
}
